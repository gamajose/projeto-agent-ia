APP_ENV=development
LOG_LEVEL=INFO

SSH_DEFAULT_USER=2com
SSH_DEFAULT_PASSWORD=
SSH_PRIVATE_KEY_PATH=
SSH_PRIVATE_KEY_PASSPHRASE=
SSH_ALLOW_AGENT=true
SSH_LOOK_FOR_KEYS=true
SSH_DEFAULT_PORT=22
SSH_CONNECT_TIMEOUT=15
SSH_COMMAND_TIMEOUT=60

POSTGRES_DSN=postgresql+psycopg://agent_ia:CHANGE_ME@127.0.0.1:5432/agent_ia
REDIS_URL=redis://127.0.0.1:6379/1

CHECKMK_API_USER=
CHECKMK_API_SECRET=
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_BASE_URL=https://api.groq.com/openai/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Agent IA Infra
OPENROUTER_SITE_URL=
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://127.0.0.1:11434

RECURRENCE_WARNING_COUNT=2
RECURRENCE_WARNING_DAYS=7
RECURRENCE_CRITICAL_COUNT=4
RECURRENCE_CRITICAL_DAYS=30

FILESYSTEM_WARNING_PERCENT=80
FILESYSTEM_CRITICAL_PERCENT=90
INODE_WARNING_PERCENT=80
INODE_CRITICAL_PERCENT=90
LOAD_WARNING_RATIO=1
LOAD_CRITICAL_RATIO=2
AGENT_MAX_ROUNDS=5
AGENT_MAX_COMMANDS=20
AGENT_MIN_CONFIDENCE=70
